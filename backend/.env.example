APP_ENV=development
DEBUG=True
PROJECT_NAME=Sakra-Finance
API_V1_STR=/api/v1
HOST=127.0.0.1
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_REFRESH_SECRET_KEY=your-jwt-refresh-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AES_ENCRYPTION_KEY=your-base64-encoded-aes-key-here
AADHAAR_SALT=your-aadhaar-salt-here
DATABASE_URL=mysql+pymysql://user:password@host:port/database
RESEND_API_KEY=your-resend-api-key-here
SENDER_EMAIL=Your Name <noreply@yourdomain.com>

GROQ_API_KEY=your-groq-api-key-here
VECTOR_DB_URL=
EMBEDDING_MODEL=all-MiniLM-L6-v2
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.2

